# Backend runtime
NODE_ENV=development
PORT=4000
DATA_DIR=./data
STORAGE_DIR=./storage
JSON_BODY_LIMIT=512kb

# Browser origins allowed to send credentialed API requests.
# Use a comma-separated FRONTEND_ORIGINS value when more than one is required.
FRONTEND_URL=http://localhost:5173
FRONTEND_ORIGINS=

# Generate a strong value, for example:
# node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=
SESSION_HOURS=12
SESSION_COOKIE_SECURE=false

# Optional providers. Keep real keys in backend/.env or a deployment secret manager.
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
